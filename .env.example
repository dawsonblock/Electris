# Electro Environment Variables
# Copy this to .env and fill in your value:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# Telegram Bot Token (required) — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Shell runner hardening
# auto   = prefer docker, then podman, fail closed if neither exists
# host   = direct host exec, only honored when ELECTRO_ENABLE_HOST_SHELL=1 too
# docker = require docker CLI
# podman = require podman CLI
ELECTRO_SHELL_BACKEND=auto

# Default isolated runner image. Build the included Dockerfile if you want a richer trusted toolchain.
ELECTRO_SHELL_CONTAINER_IMAGE=debian:bookworm-slim

# Network is denied by default for shell runs.
ELECTRO_SHELL_ALLOW_NETWORK=0

# Resource limits for the isolated shell runner.
ELECTRO_SHELL_MEMORY_MB=256
ELECTRO_SHELL_PIDS_LIMIT=128
ELECTRO_SHELL_CPU_LIMIT=1.0
ELECTRO_SHELL_TMPFS_MB=64

# Optional comma-separated env names to pass through to the host fallback after the environment is cleared.
# Example: ELECTRO_SHELL_PASSTHROUGH_ENV=OPENAI_API_KEY,ANTHROPIC_API_KEY
ELECTRO_SHELL_PASSTHROUGH_ENV=

# Only set this together with ELECTRO_SHELL_BACKEND=host on a deliberately trusted machine.
# Host fallback now points HOME/XDG directories into the workspace instead of inheriting your real home config.
ELECTRO_ENABLE_HOST_SHELL=0

# Optional comma-separated allowlist for browser and web_fetch destinations.
# Examples: ELECTRO_PUBLIC_WEB_ALLOWLIST=github.com,docs.rs
ELECTRO_PUBLIC_WEB_ALLOWLIST=

# Optional outbound proxy for browser traffic. Leave unset to connect directly.
ELECTRO_BROWSER_PROXY_SERVER=
ELECTRO_BROWSER_PROXY_BYPASS=

# Browser JavaScript evaluation is disabled by default. Only enable it on deliberately trusted tasks.
ELECTRO_BROWSER_ALLOW_EVAL=0

# Browser starts clean by default. Set to 1 only when you intentionally want to clone live Chrome session state.
ELECTRO_INHERIT_BROWSER_SESSION=0

# Browser isolation mode: remote (default), local (explicit weaker fallback)
ELECTRO_BROWSER_ISOLATION_MODE=remote
# Remote isolated browser CDP endpoint (docker-compose.browser-sandbox.yml maps this to localhost)
ELECTRO_BROWSER_REMOTE_URL=http://127.0.0.1:9223
# When local fallback is used, require an explicit outbound proxy by default
ELECTRO_BROWSER_PROXY_REQUIRED=1
