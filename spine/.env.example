# Electris Runtime Spine Environment Variables
# Copy this file to .env and add your API keys

# Server
SPINE_SERVER__PORT=8080
SPINE_SERVER__HOST=0.0.0.0

# LLM Configuration
# Supported providers: openai, anthropic, kimi
SPINE_LLM__PROVIDER=openai
SPINE_LLM__API_KEY=your-api-key-here
SPINE_LLM__MODEL=gpt-4

# For Kimi (Moonshot AI):
# SPINE_LLM__PROVIDER=kimi
# SPINE_LLM__API_KEY=your-kimi-api-key
# SPINE_LLM__MODEL=kimi-latest
SPINE_LLM__MAX_TOKENS=4000

# Worker
SPINE_WORKER__POLICY=standard

# Logging
SPINE_LOGGING__LEVEL=info
SPINE_LOGGING__FORMAT=pretty
